# ── Supabase ───────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Direct Postgres connection (bypasses PostgREST) - for bulk operations
# Find in: Supabase Dashboard → Settings → Database → Connection string (Transaction mode)
SUPABASE_DB_URL=postgresql://postgres.[ref]:[password]@aws-0-eu-north-1.pooler.supabase.com:6543/postgres

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
